# MQTT
MQTT_HOST=192.168.1.50
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=solar_assistant

# Redis
REDIS_URL=redis://localhost:6380

# Tesla Fleet API
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_REDIRECT_URI=http://your-server:5050/api/tesla/callback
TESLA_AUDIENCE=https://fleet-api.prd.eu.vn.cloud.tesla.com

# Tesla HTTP Proxy (for vehicle commands)
TESLA_PROXY_URL=https://localhost:4443

# App
SECRET_KEY=change-me-to-random-string
APP_PORT=5050
DB_PATH=/app/data/tesla_charger.db
TZ=Europe/Kyiv
